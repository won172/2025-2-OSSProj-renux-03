# RenuxServer(.NET) 환경변수 예시 — 실제 값은 절대 커밋하지 말 것.
# 운영에서는 이 파일이 아니라 시크릿 매니저(예: fly secrets set KEY=...)를 사용한다.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<db-password>
POSTGRES_DB=<db-name>
# Npgsql 연결 문자열 (POSTGRES_* 값과 일치해야 함)
CONNECTIONSTRING="Host=db; Port=5432; Database=<db-name>; Username=postgres; Password=<db-password>"

# JWT 서명 키 (base64 인코딩된 충분히 긴 무작위 키)
JWT_KEY=<base64-encoded-random-signing-key>

# RAG 서비스 (docker compose 내부 서비스명)
RAG_SERVICE_URL=http://rag-service:8000

# OpenAI (라우터/질의분석/생성에 사용)
OPENAI_API_KEY=sk-your-openai-api-key

# Redis
REDIS_URL=redis://redis:6379/0

# CORS 허용 오리진 (콤마 구분). 운영 도메인을 명시할 것.
CORS_ALLOWED_ORIGINS=https://your-domain.example

# 인증 쿠키 보안 속성 (HTTPS 운영에서는 true 권장)
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Lax
GUEST_COOKIE_SECURE=true
GUEST_COOKIE_SAMESITE=Lax
