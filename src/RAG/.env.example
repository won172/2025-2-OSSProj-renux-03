# RAG(FastAPI) 환경변수 예시 — 실제 값은 절대 커밋하지 말 것.
# 운영에서는 시크릿 매니저로 주입한다.

# OpenAI (라우터/질의분석은 항상 OpenAI 사용 → 필수)
OPENAI_API_KEY=sk-your-openai-api-key

# Redis (docker compose 내부 서비스명)
REDIS_URL=redis://redis:6379/0

# HuggingFace 토큰 (임베딩/리랭커 모델 다운로드 레이트 완화용, 선택)
HF_TOKEN=hf_your-huggingface-token

# 데이터 자동 갱신 스케줄러 (rag-service 프로세스 내부 APScheduler).
# 운영 배포에서 1로 켜면 공지/학식을 주기적으로 자동 크롤·재인덱싱한다.
RAG_SCHEDULER_ENABLED=1
RAG_NOTICES_REFRESH_HOURS=6   # 공지 갱신 주기(시간). 6 = 하루 4회
RAG_MEALS_REFRESH_HOURS=24    # 학식 갱신 주기(시간). 24 = 매일
RAG_NOTICES_REFRESH_MAX_PAGES=5
