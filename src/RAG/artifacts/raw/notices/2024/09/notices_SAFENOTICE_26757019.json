    "본문HTML": "<p>\n\n</p><p style='box-sizing: border-box; margin: 0px; padding: 0px; font-family: Pretendard, 나눔고딕, NanumGothic, \"Nanum Gothic\", 돋움, Dotum, Arial, sans-serif; font-size: 17px;'><span style=\"display: none;\"> </span><span style=\"font-size:11pt;\"><span style=\"font-family:돋움;\"><span style=\"box-sizing: border-box; letter-spacing: 0pt;\">1. </span><span style=\"box-sizing: border-box;\">관련 </span>: <span style=\"box-sizing: border-box;\">연구실 안전환경 조성에 관한 법률 제 </span><span style=\"box-sizing: border-box; letter-spacing: 0pt;\">20</span><span style=\"box-sizing: border-box;\">조</span><span style=\"box-sizing: border-box; letter-spacing: 0pt;\">(</span><span style=\"box-sizing: border-box;\">교육 </span><span style=\"box-sizing: border-box; letter-spacing: 0pt;\"><span style=\"box-sizing: border-box;\">․ </span></span><span style=\"box-sizing: border-box;\">훈련</span><span style=\"box-sizing: border-box; letter-spacing: 0pt;\">)</span></span></span></p>\n<p style=\"box-sizing: border-box; margin: 0px; padding: 0px; font-size: 17px;\"><span style=\"font-size:11pt;\"><span style=\"font-family:돋움;\"><span style=\"box-sizing: border-box; letter-spacing: 0pt;\">2. </span><span style=\"box-sizing: border-box;\">상기 법에 의거하여</span><span style=\"box-sizing: border-box; letter-spacing: 0pt;\">, 2024</span><span style=\"box-sizing: border-box;\">학년도 </span><span style=\"box-sizing: border-box;\">2</span><span style=\"box-sizing: border-box;\">학기 신규 및 정기 2차 </span><span style=\"box-sizing: border-box;\">연구실 안전교육을 아래와 같이 시행하오니 기한 내 반드시 이수하여 주시기 바랍니다</span><span style=\"box-sizing: border-box; letter-spacing: 0pt;\">.</span></span></span></p>\n<p style='box-sizing: border-box; margin: 0px; padding: 0px; font-family: Pretendard, 나눔고딕, NanumGothic, \"Nanum Gothic\", 돋움, Dotum, Arial, sans-serif; font-size: 17px;'> </p>\n<p style=\"box-sizing: border-box; margin: 0px; padding: 0px; font-size: 17px;\"><span style=\"font-size:11pt;\"><span style=\"font-family:돋움;\"><span 