    "본문HTML": "<p>\n\n</p><p><span style=\"letter-spacing:0pt;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">1. </span></span></span><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">장학명</span></span><span style=\"letter-spacing:0pt;\"><span style=\"font-family:pretendard;\">:</span></span><span style=\"letter-spacing:0pt;font-weight:bold;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">(</span></span></span><span style=\"font-weight:bold;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">부산</span></span></span><span style=\"letter-spacing:0pt;font-weight:bold;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">)</span></span></span><span style=\"font-weight:bold;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">숭림사 지역미래불자육성장학</span></span></span></p>\n<p style=\"text-autospace:none;font-size:12.0pt;\"> </p>\n<p><span style=\"letter-spacing:0pt;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">2. </span></span></span><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">후원 사찰</span></span>: <span style=\"font-size:13.0pt;\"><span style=\"font-family:동국체;\">부산 숭림사</span></span></p>\n<p style=\"text-autospace:none;font-size:12.0pt;\"> </p>\n<p><span style=\"letter-spacing:0pt;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">3. </span></span></span><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">장학금</span></span><span style=\"letter-spacing:0pt;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">: 100</span></span></span><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">만원</span></span><span style=\"letter-spacing:0pt;\"><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">(</span></span></span><span style=\"font-size:12.0pt;\"><span style=\"font-family:동국체;\">생활비성</span></span><span style=\"letter-spacing:0pt;\"><span style=\"font-s