.vs/
__*/
**/bin/
**/obj/
*.env
*.env.*
# 단, 플레이스홀더만 담은 .env.example 은 추적해 신규 배포/기여자 가이드로 쓴다.
!*.env.example
!**/.env.example
RenuxServer.csproj.Backup.tmp
RenuxServer.csproj.user
.DS_Store
**/.DS_Store
**/huggingface_cache

# Local environment files
src/RAG/.env
src/RenuxServer/.env
src/RenuxServer/.env.docker.local
src/RenuxServer/wwwroot/frontend/.env*

# Local databases
*.db
*.sqlite
*.sqlite3

# DB dumps (PII 위험 — 저장소에 커밋 금지)
*.sql
!src/RenuxServer/Migrations/**/*.sql
src/RAG/rag_data.db
src/RAG/rag_database.db
src/RAG/src/rag_database.db

# Local RAG artifacts
src/RAG/artifacts/raw/
src/RAG/artifacts/normalized/
src/RAG/artifacts/chunks/
src/RAG/artifacts/vectorizers/
# 단, *_tfidf.pkl 과 manifest.json(무결성 검증 기준)은 `git add -f`로 추적 중 — 함께 커밋할 것.
src/RAG/artifacts/vectorizers_backup_*/
src/RAG/artifacts/models/
src/RAG/artifacts/db_chroma/

# RAG 평가 결과(생성물)
src/RAG/tests/evaluation_results_*.csv

# 작업용 문서(소스 아님 — 저장소에 올리지 않음)
/CODE_REVIEW.md
/FEATURE_MAP.md
/UI_REVIEW.md
/ADMIN_REVIEW.md
/KNOWLEDGE_FLOW_REVIEW.md
/LAUNCH_READINESS.md
/CLAUDE.md

# 어시스턴트/로컬 작업 디렉터리
/.claude/

# 인스타 홍보용 이미지 + 이미지 생성 코드/폰트 (소스 아님)
/insta/
/canvas-design/

# 발표/시연 산출물·대용량 비소스 (저장소에 올리지 않음)
/video/
/발표자료/
/GEMINI.md
# doc/ 의 보고서·발표자료·시연영상(대용량)은 제외하되, README가 참조하는 doc/images 는 유지
/doc/*
!/doc/images/
